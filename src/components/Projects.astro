---
const featuredProjects = [
  {
    number: "01",
    name: "KutAgenda",
    description:
      "Sistema de agendamento online que permite gerenciar horários, profissionais e atendimentos de forma simples e eficiente, melhorando a organização e a experiência do cliente.",
    stack: ["Next.js", "Node.js", "MongoDB"],
    liveUrl: "https://kutagenda.com.br",
    image: "/projects/kutagenda.avif",
  },
  {
    number: "02",
    name: "SAEGA",
    description:
      "Sistema de gestão de fazendas desenvolvido para organizar operações agrícolas, controle de produção e gestão de recursos, trazendo mais eficiência e tomada de decisão para o produtor rural.",
    stack: ["React", "Java", "PostgreSQL"],
    liveUrl: "https://app.saega.com.br/",
    image: "/projects/saega.avif",
  },
  {
    number: "03",
    name: "Agrocenso",
    description:
      "Software de censo agrícola inspirado no modelo do IBGE, focado na coleta e análise de dados do setor rural, permitindo levantamentos precisos e geração de relatórios estratégicos.",
    stack: ["React", "Java", "PostgreSQL"],
    liveUrl: "https://app.agrocenso.com.br/",
    image: "/projects/agrocenso.avif",
  },
];

const smallerProjects = [
  {
    name: "NebulaBot",
    description:
      "Bot de trading para Binance que utiliza estratégias automatizadas para executar operações com base em indicadores de mercado.",
    stack: ["Python"],
    githubUrl: "https://github.com/HudsonDevWeb/NebulaBot",
    liveUrl: "https://github.com/HudsonDevWeb/NebulaBot",
  },
  {
    name: "MailBot",
    description:
      "Ferramenta para envio de e-mails em massa de forma automatizada, ideal para campanhas e notificações.",
    stack: ["Python"],
    githubUrl: "https://github.com/HudsonDevWeb/mailBot",
    liveUrl: "https://github.com/HudsonDevWeb/mailBot",
  },
  {
    name: "WhatsApp CLI",
    description:
      "Interface de linha de comando para utilização do WhatsApp diretamente no terminal, focada em praticidade e automação.",
    stack: ["Node.js"],
    githubUrl: "https://github.com/HudsonDevWeb/whatsapp-cli",
    liveUrl: "https://github.com/HudsonDevWeb/whatsapp-cli",
  },
  {
    name: "Pokedex Mobile",
    description:
      "Aplicativo mobile desenvolvido em React Native para busca e visualização de informações de Pokémons.",
    stack: ["React Native"],
    githubUrl: "https://github.com/HudsonDevWeb/Pokedex-Mobile",
    liveUrl: "https://github.com/HudsonDevWeb/Pokedex-Mobile",
  },
  {
    name: "Telegram Scheduler Bot",
    description:
      "Bot para Telegram que permite criar eventos no Google Agenda enviando título e horário diretamente pelo chat.",
    stack: ["Python"],
    githubUrl: "https://github.com/HudsonDevWeb/bot_lembretes",
    liveUrl: "https://github.com/HudsonDevWeb/bot_lembretes",
  },
  {
    name: "Fitness Training App",
    description:
      "Aplicativo desenvolvido em bootcamp para gerenciamento de treinos de academia, com foco em organização e acompanhamento.",
    stack: ["React Native"],
    githubUrl: "https://github.com/HudsonDevWeb/bootcamp_api",
    liveUrl: "https://github.com/HudsonDevWeb/bootcamp_api",
  },
];
---

<section id="projetos" class="projects-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// projetos</span>
      <h2 class="section-title">Trabalhos Selecionados</h2>
    </div>

    <div class="featured-list">
      {
        featuredProjects.map((project, index) => {
          const reversed = index % 2 === 1;
          return (
            <article
              class:list={["featured-card", { reversed }]}
              style={`--delay: ${index * 0.15}s`}
            >
              <div class="featured-text">
                <span class="project-number">{project.number}</span>
                <h3 class="project-title">{project.name}</h3>
                <p class="project-description">{project.description}</p>

                <div class="project-stack">
                  {project.stack.map((tech) => (
                    <span class="stack-tag">{tech}</span>
                  ))}
                </div>

                <div class="project-links">
                  <a
                    href={project.liveUrl}
                    class="project-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Ver projeto
                    <span class="arrow">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </svg>
                    </span>
                  </a>
                </div>
              </div>

              <div class="featured-image">
                <div
                  class="image-placeholder"
                  role="img"
                  aria-label={`Preview do projeto ${project.name}`}
                >
                  <img
                    src={project.image}
                    alt={project.name}
                    width="560"
                    height="360"
                    loading="lazy"
                  />
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <details class="more-projects">
      <summary>
        <span class="more-icon">+</span>
        Ver mais projetos
      </summary>
      <div class="smaller-grid">
        {
          smallerProjects.map((project) => (
            <div class="small-card">
              <h4 class="small-title">{project.name}</h4>
              <p class="small-desc">{project.description}</p>
              <div class="small-stack">
                {project.stack.map((tech) => (
                  <span class="stack-tag">{tech}</span>
                ))}
              </div>
              <div class="small-links">
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="small-link"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77 5.44 5.44 0 0 0 3.5 9.5c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                  </svg>
                  GitHub
                </a>
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="small-link"
                >
                  Ver{" "}
                  <span class="arrow">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </span>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </details>
  </div>
</section>

<style>
  .projects-section {
    padding: 6rem 0;
  }

  .section-header {
    margin-bottom: 4rem;
  }

  .section-label {
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: "Syne", sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  .featured-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-number {
    font-family: "Syne", sans-serif;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .project-title {
    font-family: "Syne", sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .project-description {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-tag {
    font-size: 0.75rem;
    background: var(--accent-dim);
    color: var(--text-secondary);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    font-family: "Courier New", monospace;
  }

  .project-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.5rem;
  }

  .project-link {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-link:hover {
    opacity: 0.8;
  }

  .project-link .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .project-link:hover .arrow {
    transform: translateX(4px);
  }

  .github-link {
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.2s ease;
  }

  .github-link:hover {
    color: var(--text-primary);
  }

  .featured-image {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .image-placeholder {
    aspect-ratio: 16 / 10;
    background: var(--bg-secondary);
    box-shadow: inset 0 0 0 2px dashed var(--border);
    border-radius: 12px;
  }

  .image-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .featured-card:not(.reversed) {
      grid-template-columns: 1fr 1fr;
    }

    .featured-card.reversed {
      grid-template-columns: 1fr 1fr;
    }

    .featured-card:not(.reversed) .featured-text {
      order: 1;
    }

    .featured-card:not(.reversed) .featured-image {
      order: 2;
    }

    .featured-card.reversed .featured-text {
      order: 2;
    }

    .featured-card.reversed .featured-image {
      order: 1;
    }
  }

  .more-projects {
    margin-top: 4rem;
    border-top: 1px solid var(--border);
    border-radius: 12px;
  }

  .more-projects summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
  }

  .more-projects summary::-webkit-details-marker {
    display: none;
  }

  .more-projects summary:hover {
    color: var(--text-primary);
  }

  .more-icon {
    font-size: 1.25rem;
  }

  .smaller-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .small-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.3s ease;
  }

  .small-card:hover {
    transform: translateY(-4px);
  }

  .small-title {
    font-family: "Syne", sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }

  .small-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .small-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .small-links {
    display: flex;
    gap: 1rem;
    margin-top: auto;
  }

  .small-link {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.2s ease;
  }

  .small-link:hover {
    color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .smaller-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
