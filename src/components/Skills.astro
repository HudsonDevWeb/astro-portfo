---

<section id="habilidades" class="skills-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// habilidades</span>
      <h2 class="section-title">Meu Stack Técnico</h2>
    </div>

    <div class="bento-grid">
      {
        categories.map((cat) => (
          <div class={`bento-card accent-${cat.accent}`}>
            <div class="card-header">
              <span class="card-title">{cat.name}</span>
              <span class="card-count">{cat.items.length}</span>
            </div>

            <div class="skills-grid">
              {cat.items.map((skill) => (
                <div class="skill-item">
                  <div class="skill-icon" set:html={skill.icon} />
                  <div class="skill-info">
                    <span class="skill-name">{skill.name}</span>
                    <span class="skill-desc">{skill.desc}</span>
                  </div>
                  <div class="skill-dots">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <span class={`dot ${i < skill.level ? "filled" : ""}`} />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 6rem 0;
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .section-label {
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: "Syne", sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .bento-card:hover::before {
    opacity: 0.1;
  }

  .bento-card.accent-sky::before {
    background: #38bdf8;
  }
  .bento-card.accent-emerald::before {
    background: #34d399;
  }
  .bento-card.accent-amber::before {
    background: #fbbf24;
  }
  .bento-card.accent-violet::before {
    background: #a78bfa;
  }

  .bento-card {
    border-left-width: 3px;
  }
  .bento-card.accent-sky {
    border-left-color: #38bdf8;
  }
  .bento-card.accent-emerald {
    border-left-color: #34d399;
  }
  .bento-card.accent-amber {
    border-left-color: #fbbf24;
  }
  .bento-card.accent-violet {
    border-left-color: #a78bfa;
  }

  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .card-title {
    font-family: "Syne", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .card-count {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--accent-dim);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-item {
    display: grid;
