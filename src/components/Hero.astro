---
const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/HudsonDevWeb",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77 5.44 5.44 0 0 0 3.5 9.5c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
</svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/hudsondevweb/",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: "Email",
    href: "mailto:hudsonmoreiraoliveira501@gmail.com",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
];
---

<section id="hero" class="hero">
  <div class="container hero-container">
    <div class="hero-text">
      <span class="tag fade-in">&lt; Desenvolvedor Full Stack /&gt;</span>
      <h1 class="fade-in fade-in-delay-1">
        Eu sou<br />
        <span class="highlight">Hudson Moreira.</span>
      </h1>
      <p class="fade-in fade-in-delay-2">
        Construo interfaces modernas e sistemas robustos do front ao back, do
        banco ao deploy. Transformo ideias em produtos digitais completos.
      </p>

      <div class="social-links fade-in fade-in-delay-3">
        {
          socialLinks.map((social) => (
            <a href={social.href} class="social-link" aria-label={social.label}>
              <span set:html={social.icon} aria-hidden="true" />
              <span>{social.label}</span>
            </a>
          ))
        }
      </div>

      <div style="gap: 10px; display: flex; flex-wrap: wrap;">
        <a
          href="https://wa.me/5579999869055"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn cta-btn--solid fade-in fade-in-delay-4"
        >
          Fale comigo
        </a>
        <a
          href="#projetos"
          class="cta-btn cta-btn--outline fade-in fade-in-delay-4"
        >
          Ver meus projetos <span class="arrow"></span>
        </a>
      </div>
    </div>

    <div class="hero-image fade-in fade-in-delay-3">
      <div class="image-wrapper">
        <img
          src="/perfil.avif"
          alt="Hudson Moreira"
          width="480"
          height="600"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 4rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tag {
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  h1 {
    font-family: "Syne", sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
  }

  .highlight {
    color: #ffffff;
  }

  .hero-text p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 540px;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .social-link span:last-child {
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s ease;
  }

  .social-link:hover {
    color: var(--text-primary);
  }

  .social-link:hover span:last-child {
    text-decoration-color: var(--text-primary);
  }

  .social-link svg {
    flex-shrink: 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
    width: fit-content;
  }

  .cta-btn--solid {
    background: #ffffff;
    color: #0a0a0a;
  }

  .cta-btn--solid:hover {
    transform: translateY(-2px);
    opacity: 1;
  }

  .cta-btn--outline {
    background: transparent;
    color: #ffffff;
    border: 1px solid var(--text-muted);
  }

  .cta-btn--outline:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--text-primary);
  }

  .arrow {
    transition: transform 0.2s ease;
  }

  .cta-btn:hover .arrow {
    transform: translateX(3px);
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .image-wrapper {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 0 60px rgba(255, 255, 255, 0.04);
    max-width: 380px;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--bg-secondary);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.3s ease;
  }

  .image-wrapper:hover img {
    filter: grayscale(0%);
  }

  @media (min-width: 768px) {
    .hero {
      padding: 8rem 0 6rem;
    }

    .hero-container {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    h1 {
      font-size: clamp(2.2rem, 6vw, 3.5rem);
    }

    .image-wrapper {
      max-width: 420px;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 10rem 0 6rem;
    }

    .hero-container {
      gap: 5rem;
    }
  }
</style>
