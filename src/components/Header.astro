---
const navItems = [
  { href: "#habilidades", label: "Habilidades", number: "01" },
  { href: "#experiencia", label: "Experiencia", number: "02" },
  { href: "#projetos", label: "Projetos", number: "03" },
];
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <img src="/logo_hm.avif" alt="Logo hm" width="100" loading="eager" />
    <span class="logo-line"></span>

    <nav class="desktop-nav" aria-label="Navegacao principal">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>
                <span class="nav-number">{item.number}</span>
                <span class="nav-label">{item.label}</span>
                <span class="nav-indicator" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="sidebar-divider"></div>

    <div class="sidebar-status">
      <span class="status-dot"></span>
      <span class="status-text">Disponivel</span>
    </div>

    <div class="sidebar-social">
      <a
        href="https://github.com/HudsonDevWeb"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56v-2.02c-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.73.08-.72.08-.72 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.27 1.2-3.07-.12-.3-.52-1.52.11-3.17 0 0 .97-.31 3.18 1.17a11.1 11.1 0 0 1 5.8 0c2.2-1.48 3.17-1.17 3.17-1.17.63 1.65.23 2.87.11 3.17.75.8 1.2 1.82 1.2 3.07 0 4.41-2.69 5.38-5.25 5.66.41.35.77 1.05.77 2.12v3.15c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12C23.5 5.74 18.27.5 12 .5z"
          ></path></svg
        >
      </a>
      <a
        href="https://www.linkedin.com/in/hudsondevweb/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect width="4" height="12" x="2" y="9"></rect><circle
            cx="4"
            cy="4"
            r="2"></circle></svg
        >
      </a>
      <a href="mailto:hudsonmoreiraoliveira501@gmail.com" aria-label="Email">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
      </a>
    </div>

    <a href="/HudsonDesenvolvedor.pdf" download class="download-btn">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
          points="7 10 12 15 17 10"></polyline><line
          x1="12"
          y1="15"
          x2="12"
          y2="3"></line></svg
      >
      <span>Curriculo</span>
    </a>
  </div>
</aside>

<header class="mobile-header">
  <img src="/logo_hm.avif" alt="Logo hm" width="80" loading="eager" />
  <details class="mobile-menu">
    <summary aria-label="Abrir menu">
      <svg
        class="menu-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="4" y1="7" x2="20" y2="7"></line><line
          x1="4"
          y1="12"
          x2="20"
          y2="12"></line><line x1="4" y1="17" x2="20" y2="17"></line></svg
      >
      <svg
        class="close-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="18" y1="6" x2="6" y2="18"></line><line
          x1="6"
          y1="6"
          x2="18"
          y2="18"></line></svg
      >
    </summary>
    <nav class="mobile-nav">
      <div class="mobile-nav-inner">
        {
          navItems.map((item) => (
            <a href={item.href}>
              <span class="mobile-number">{item.number}</span>
              <span class="mobile-label">{item.label}</span>
            </a>
          ))
        }
        <div class="mobile-divider"></div>
        <a href="/HudsonDesenvolvedor.pdf" download class="mobile-download">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
            ></path><polyline points="7 10 12 15 17 10"></polyline><line
              x1="12"
              y1="15"
              x2="12"
              y2="3"></line></svg
          >
          Baixar Curriculo
        </a>
        <div class="mobile-social">
          <a
            href="https://github.com/HudsonDevWeb"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
          >
            <svg viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56v-2.02c-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.73.08-.72.08-.72 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.27 1.2-3.07-.12-.3-.52-1.52.11-3.17 0 0 .97-.31 3.18 1.17a11.1 11.1 0 0 1 5.8 0c2.2-1.48 3.17-1.17 3.17-1.17.63 1.65.23 2.87.11 3.17.75.8 1.2 1.82 1.2 3.07 0 4.41-2.69 5.38-5.25 5.66.41.35.77 1.05.77 2.12v3.15c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12C23.5 5.74 18.27.5 12 .5z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.linkedin.com/in/hudsondevweb/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
          <a href="mailto:contato@hudson.dev" aria-label="Email">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
          </a>
        </div>
      </div>
    </nav>
  </details>
</header>

<style>
  .sidebar {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 260px;
    height: 100vh;
    z-index: 200;
    background: var(--bg-primary);
    border-right: 1px solid var(--border);
    padding: 2rem 0;
    transition: box-shadow 0.3s ease;
  }

  .sidebar::after {
    content: "";
    position: absolute;
    top: 0;
    right: -40px;
    width: 40px;
    height: 100%;
    background: linear-gradient(to right, rgba(10, 10, 10, 0.06), transparent);
    pointer-events: none;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0 1.5rem;
  }

  /* Logo */
  .logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    text-decoration: none;
    padding-bottom: 1.5rem;
  }

  .logo-mark {
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: 1.35rem;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    transition: opacity 0.2s ease;
  }

  .logo:hover .logo-mark {
    opacity: 0.7;
  }

  .logo-line {
    width: 64px;
    height: 2px;
    background: var(--text-muted);
    border-radius: 2px;
    transition:
      width 0.3s ease,
      background 0.3s ease;
  }

  .logo:hover .logo-line {
    width: 48px;
    background: var(--text-primary);
  }

  /* Navigation */
  .desktop-nav {
    flex: 1;
    padding-top: 0.5rem;
  }

  .desktop-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    list-style: none;
  }

  .desktop-nav a {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-secondary);
    transition:
      color 0.2s ease,
      background 0.2s ease,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .desktop-nav a:hover {
    color: var(--text-primary);
    background: var(--accent-dim);
    opacity: 1;
  }

  .desktop-nav a .nav-indicator {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleY(0);
    width: 3px;
    height: 60%;
    background: var(--text-primary);
    border-radius: 0 2px 2px 0;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .desktop-nav a:hover .nav-indicator {
    transform: translateY(-50%) scaleY(1);
  }

  .nav-number {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .desktop-nav a:hover .nav-number {
    color: var(--text-secondary);
  }

  .nav-label {
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
  }

  /* Divider */
  .sidebar-divider {
    height: 1px;
    background: var(--border);
    margin: 1rem 0;
  }

  /* Status */
  .sidebar-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.75rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.4);
    animation: pulseGreen 2s ease-in-out infinite;
  }

  .status-text {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Social */
  .sidebar-social {
    display: flex;
    gap: 0.25rem;
    padding: 0.75rem 0;
  }

  .sidebar-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .sidebar-social a:hover {
    color: var(--text-primary);
    background: var(--accent-dim);
    opacity: 1;
    transform: translateY(-2px);
  }

  .sidebar-social a :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* Download Button */
  .download-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: auto;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .download-btn:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
    background: var(--accent-dim);
    opacity: 1;
  }

  /* =========================================================
     MOBILE TOP BAR
     ========================================================= */
  .mobile-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    height: 56px;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid var(--border);
  }

  .mobile-logo {
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: opacity 0.2s ease;
  }

  .mobile-logo:hover {
    opacity: 0.7;
  }

  /* Mobile menu via <details> */
  .mobile-menu {
    position: relative;
  }

  .mobile-menu summary {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    cursor: pointer;
    list-style: none;
    border-radius: 8px;
    transition: background 0.2s ease;
    position: relative;
  }

  .mobile-menu summary:hover {
    background: var(--accent-dim);
  }

  .mobile-menu summary::-webkit-details-marker,
  .mobile-menu summary::marker {
    display: none;
  }

  .close-icon {
    display: none;
    color: var(--text-primary);
  }

  .mobile-menu[open] summary .menu-icon {
    display: none;
  }

  .mobile-menu[open] summary .close-icon {
    display: block;
  }

  .mobile-nav {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: 260px;
    max-height: calc(100vh - 80px);
    overflow-y: auto;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .mobile-nav-inner {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
  }

  .mobile-nav a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0.85rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .mobile-nav a:hover {
    color: var(--text-primary);
    background: var(--accent-dim);
    opacity: 1;
  }

  .mobile-number {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .mobile-divider {
    height: 1px;
    background: var(--border);
    margin: 0.5rem 0;
  }

  .mobile-download {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem;
    margin: 0.25rem 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .mobile-download:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
    opacity: 1;
  }

  .mobile-social {
    display: flex;
    gap: 0.25rem;
    padding-top: 0.5rem;
  }

  .mobile-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  .mobile-social a:hover {
    color: var(--text-primary);
    background: var(--accent-dim);
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .sidebar {
      display: block;
    }

    .mobile-header {
      display: none;
    }
  }
</style>
