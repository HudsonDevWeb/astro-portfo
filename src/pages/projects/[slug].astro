---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkillBadge from '../../components/SkillBadge.astro';
import { formatDate } from '../../utils/formatDate';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <div class="container">
    <article class="project-details">
      <header class="project-header">
        <a href="/projects" class="back-link">&larr; Voltar para projetos</a>
        <div class="meta">
          <time datetime={project.data.date.toISOString()}>
            {formatDate(project.data.date)}
          </time>
        </div>
        <h1>{project.data.title}</h1>
        <p class="subtitle">{project.data.description}</p>
        
        <div class="tech-tags">
          {project.data.tech.map((t) => <SkillBadge name={t} />)}
        </div>

        <div class="project-links">
          {project.data.github && (
            <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="btn btn-github">
              GitHub
            </a>
          )}
          {project.data.demo && (
            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="btn btn-demo">
              Live Demo
            </a>
          )}
        </div>
      </header>

      {project.data.image && (
        <div class="featured-image">
          <img src={project.data.image} alt={project.data.title} />
        </div>
      )}

      <div class="content">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .project-details {
    max-width: 800px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--secondary-text);
  }

  .back-link:hover {
    color: var(--accent-color);
  }

  .project-header {
    margin-bottom: 3rem;
  }

  .meta {
    font-size: 0.875rem;
    color: var(--secondary-text);
    margin-bottom: 0.5rem;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--secondary-text);
    margin-bottom: 2rem;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-github {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
  }

  .btn-demo {
    background-color: var(--accent-color);
    color: white;
  }

  .btn-demo:hover {
    background-color: var(--accent-hover);
  }

  .featured-image {
    margin-bottom: 3rem;
    border-radius: 1rem;
    overflow: hidden;
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    padding: 2rem;
  }

  .featured-image img {
    width: 100%;
    height: auto;
  }

  .content {
    line-height: 1.8;
    color: var(--text-color);
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
  }

  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
  }

  .content :global(p) {
    margin-bottom: 1.5rem;
  }

  .content :global(ul) {
    list-style: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
