---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillBadge from "../components/SkillBadge.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const skills = [
  "JavaScript",
  "TypeScript",
  "Node.js",
  "Astro",
  "React",
  "PostgreSQL",
  "Tailwind CSS",
  "Git",
];

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Home"
  description="Bem-vindo ao meu portfólio profissional de desenvolvedor."
>
  <div class="container">
    <section class="hero">
      <div class="hero-content">
        <h1>
          Olá, eu sou um <span class="text-gradient"
            >Desenvolvedor Full Stack</span
          >
        </h1>
        <p class="hero-description">
          Especializado em construir aplicações web modernas, rápidas e
          acessíveis. Focado em performance e experiência do usuário.
        </p>
        <div class="hero-actions">
          <a href="/projects" class="btn btn-primary">Ver Projetos</a>
          <a href="/contact" class="btn btn-secondary">Contato</a>
        </div>
        <div class="hero-social">
          <a href="https://github.com" target="_blank" rel="noopener">GitHub</a>
          <span class="dot">•</span>
          <a href="https://linkedin.com" target="_blank" rel="noopener"
            >LinkedIn</a
          >
        </div>
      </div>
    </section>

    <section id="skills" class="skills-section">
      <h2 class="section-title">Minhas Tecnologias</h2>
      <div class="skills-grid">
        {skills.map((skill) => <SkillBadge name={skill} />)}
      </div>
    </section>

    <section id="featured-projects">
      <div class="section-header">
        <h2 class="section-title">Projetos em Destaque</h2>
        <a href="/projects" class="view-all">Ver todos &rarr;</a>
      </div>
      <div class="projects-grid">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tech={project.data.tech}
              slug={project.id}
              image={project.data.image}
            />
          ))
        }
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-card">
        <h2>Gostou do que viu?</h2>
        <p>Estou sempre aberto a novos projetos e colaborações.</p>
        <a href="/contact" class="btn btn-primary">Vamos conversar</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0;
    text-align: center;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--accent-color), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--secondary-text);
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--accent-color);
    color: white;
  }

  .btn-primary:hover {
    background-color: var(--accent-hover);
    color: white;
  }

  .btn-secondary {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
  }

  .btn-secondary:hover {
    border-color: var(--accent-color);
  }

  .hero-social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    color: var(--secondary-text);
    font-size: 0.875rem;
  }

  .dot {
    opacity: 0.5;
  }

  .skills-section {
    text-align: center;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .view-all {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent-color);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .cta-section {
    margin-top: 4rem;
  }

  .cta-card {
    background: linear-gradient(
      rgba(59, 130, 246, 0.05),
      rgba(59, 130, 246, 0.05)
    );
    border: 1px solid var(--card-border);
    border-radius: 1rem;
    padding: 3rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 0;
    }
    .hero-actions {
      flex-direction: column;
    }
    .cta-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
